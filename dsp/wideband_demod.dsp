// wideband_demod.dsp — DeMoD Wideband BPSK Demodulator (40–192 kHz carrier)
//
// 2 inputs  (I, Q baseband from SoapySDR CF32 RX stream)
// 1 output  (soft BPSK symbol decisions: +1.0 ≈ bit 1, −1.0 ≈ bit 0)
//
// Architecture:
//   Costas loop (carrier/phase recovery) → matched RRC filter → soft slicer output
//
// Costas loop is a 2nd-order PLL that recovers the suppressed carrier from a
// BPSK signal. Phase error = I_arm × Q_arm; loop filter is proportional +
// integral (PI) with critically-damped (ζ = 0.707) gain schedule derived from
// the normalised loop bandwidth (loop_bw):
//
//   Kp = 4·ζ·BL          (proportional gain)
//   Ki = 4·BL²           (integral gain — second-order loop)
//
// For wideband operation (96 kbaud, sps≈21) the Costas loop must acquire faster.
// loop_bw default is raised to 0.04 (vs 0.02 for 9600 baud) to widen the
// pull-in range at the cost of a slightly noisier lock.
//
// RRC matched filter:
//   rrc_mode=0 → 301-tap (sps=50, 40 kbaud)
//   rrc_mode=1 → 125-tap (sps≈20.83, 96 kbaud)
// Coefficients are identical to the transmit filter (zero ISI at symbol instants).
//
// Parameters:
//   /wideband_demod/symbol_rate  — must match TX (40000 or 96000)
//   /wideband_demod/loop_bw      — Costas BL (0.001–0.1), default 0.04
//   /wideband_demod/mf_bw        — matched filter BW (relative, 0.1–1.0)
//   /wideband_demod/output_gain  — soft symbol scale
//   /wideband_demod/rrc_mode     — 0=301-tap/40k, 1=125-tap/96k
//
// Build:
//   faust -a ../arch/soapy-sdr-lib.cpp -lang c++ -vec -vs 256 \
//         dsp/wideband_demod.dsp -o build/wideband_demod_gen.cpp
//
// DeMoD LLC — GPL-3.0

import("stdfaust.lib");
import("oscillators.lib");
import("filters.lib");
import("maths.lib");

// ── Parameters ────────────────────────────────────────────────────────────────
symbol_rate  = hslider("/wideband_demod/symbol_rate",  40000, 40000, 96000, 1) : si.smoo;
// loop_bw: normalised Costas loop bandwidth.
// 40k: 0.02–0.03 (50 sps gives more averaging)
// 96k: 0.04–0.06 (21 sps needs wider BL to pull in quickly)
loop_bw      = hslider("/wideband_demod/loop_bw",      0.04,  0.001, 0.10, 0.001);
mf_bw        = hslider("/wideband_demod/mf_bw",        0.5,   0.1,   1.0,  0.01);
output_gain  = hslider("/wideband_demod/output_gain",   1.0,   0.0,   4.0,  0.01);
rrc_mode     = hslider("/wideband_demod/rrc_mode",      0,     0,     1,    1) : int;

// ── Costas loop (PI phase-locked loop) ───────────────────────────────────────
// Second-order loop: tracks constant frequency offset.
// ζ = 0.707 (Butterworth / critically-damped).
// Kp ≈ 4·ζ·BL,  Ki ≈ 4·BL² for small BL.
zeta = 0.707;
kp   = 4.0 * zeta * loop_bw;
ki   = 4.0 * loop_bw * loop_bw;

costas_loop(i_in, q_in) =
  letrec {
    'vco_phase   = (vco_phase + vco_freq) : ma.modulo(2.0 * ma.PI);
    'vco_i       = cos(vco_phase);
    'vco_q       = sin(vco_phase);
    // Mix: rotate incoming IQ by −VCO phase
    'baseband_i  = i_in * vco_i + q_in * vco_q;   // data arm
    'baseband_q  = i_in * vco_q - q_in * vco_i;   // error arm
    // Phase error (soft): I·Q → 0 at lock, sign gives rotation direction
    'phase_err   = baseband_i * baseband_q;
    // PI loop filter
    'freq_int    = freq_int + ki * phase_err;
    'vco_freq    = kp * phase_err + freq_int;
  }
  in baseband_i;

// ── RRC Matched Filter — 301-tap (40 kbaud, sps=50) ─────────────────────────
// Identical coefficients to wideband_mod.dsp transmit filter.
// RRC TX * RRC RX = RC (raised cosine) → zero ISI at symbol centres.
rrc40k_coeffs = waveform {
  -0.000059532, -0.000073906, -0.000089376, -0.000105675, -0.000122458, -0.000139292, -0.000155653,
  -0.000170921, -0.000184377, -0.000195201, -0.000202471, -0.000205164, -0.000202162, -0.000192253,
  -0.000174141, -0.000146458, -0.000107771, -0.000056605, 0.000008548, 0.000089202, 0.000186855,
  0.000302964, 0.000438918, 0.000596004, 0.000775375, 0.000978014, 0.001204700, 0.001455965,
  0.001732057, 0.002032899, 0.002358050, 0.002706662, 0.003077444, 0.003468622, 0.003877902,
  0.004302442, 0.004738817, 0.005182997, 0.005630324, 0.006075499, 0.006512571, 0.006934936,
  0.007335341, 0.007705900, 0.008038112, 0.008322896, 0.008550628, 0.008711193, 0.008794050,
  0.008788294, 0.008682746, 0.008466041, 0.008126732, 0.007653401, 0.007034783, 0.006259895,
  0.005318178, 0.004199644, 0.002895029, 0.001395955, -0.000304906, -0.002213663, -0.004335036,
  -0.006672186, -0.009226543, -0.011997645, -0.014982965, -0.018177768, -0.021574952, -0.025164916,
  -0.028935435, -0.032871544, -0.036955444, -0.041166423, -0.045480798, -0.049871872, -0.054309923,
  -0.058762206, -0.063192990, -0.067563614, -0.071832572, -0.075955627, -0.079885955, -0.083574310,
  -0.086969225, -0.090017237, -0.092663144, -0.094850281, -0.096520831, -0.097616154, -0.098077140,
  -0.097844587, -0.096859594, -0.095063970, -0.092400660, -0.088814181, -0.084251065, -0.078660309,
  -0.071993827, -0.064206893, -0.055258592, -0.045112252, -0.033735861, -0.021102480, -0.007190622,
  0.008015382, 0.024525052, 0.042341453, 0.061460928, 0.081872863, 0.103559495, 0.126495762,
  0.150649199, 0.175979878, 0.202440398, 0.229975926, 0.258524289, 0.288016114, 0.318375025,
  0.349517887, 0.381355102, 0.413790960, 0.446724026, 0.480047590, 0.513650146, 0.547415921,
  0.581225443, 0.614956136, 0.648482957, 0.681679053, 0.714416443, 0.746566719, 0.778001759,
  0.808594451, 0.838219423, 0.866753760, 0.894077731, 0.920075492, 0.944635776, 0.967652563,
  0.989025716, 1.008661597, 1.026473637, 1.042382866, 1.056318406, 1.068217906, 1.078027934,
  1.085704308, 1.091212373, 1.094527220, 1.095633841, 1.094527220, 1.091212373, 1.085704308,
  1.078027934, 1.068217906, 1.056318406, 1.042382866, 1.026473637, 1.008661597, 0.989025716,
  0.967652563, 0.944635776, 0.920075492, 0.894077731, 0.866753760, 0.838219423, 0.808594451,
  0.778001759, 0.746566719, 0.714416443, 0.681679053, 0.648482957, 0.614956136, 0.581225443,
  0.547415921, 0.513650146, 0.480047590, 0.446724026, 0.413790960, 0.381355102, 0.349517887,
  0.318375025, 0.288016114, 0.258524289, 0.229975926, 0.202440398, 0.175979878, 0.150649199,
  0.126495762, 0.103559495, 0.081872863, 0.061460928, 0.042341453, 0.024525052, 0.008015382,
  -0.007190622, -0.021102480, -0.033735861, -0.045112252, -0.055258592, -0.064206893, -0.071993827,
  -0.078660309, -0.084251065, -0.088814181, -0.092400660, -0.095063970, -0.096859594, -0.097844587,
  -0.098077140, -0.097616154, -0.096520831, -0.094850281, -0.092663144, -0.090017237, -0.086969225,
  -0.083574310, -0.079885955, -0.075955627, -0.071832572, -0.067563614, -0.063192990, -0.058762206,
  -0.054309923, -0.049871872, -0.045480798, -0.041166423, -0.036955444, -0.032871544, -0.028935435,
  -0.025164916, -0.021574952, -0.018177768, -0.014982965, -0.011997645, -0.009226543, -0.006672186,
  -0.004335036, -0.002213663, -0.000304906, 0.001395955, 0.002895029, 0.004199644, 0.005318178,
  0.006259895, 0.007034783, 0.007653401, 0.008126732, 0.008466041, 0.008682746, 0.008788294,
  0.008794050, 0.008711193, 0.008550628, 0.008322896, 0.008038112, 0.007705900, 0.007335341,
  0.006934936, 0.006512571, 0.006075499, 0.005630324, 0.005182997, 0.004738817, 0.004302442,
  0.003877902, 0.003468622, 0.003077444, 0.002706662, 0.002358050, 0.002032899, 0.001732057,
  0.001455965, 0.001204700, 0.000978014, 0.000775375, 0.000596004, 0.000438918, 0.000302964,
  0.000186855, 0.000089202, 0.000008548, -0.000056605, -0.000107771, -0.000146458, -0.000174141,
  -0.000192253, -0.000202162, -0.000205164, -0.000202471, -0.000195201, -0.000184377, -0.000170921,
  -0.000155653, -0.000139292, -0.000122458, -0.000105675, -0.000089376, -0.000073906, -0.000059532
};
rrc40k_coeff(n)  = rrc40k_coeffs, int(n) : rdtable;
rrc40k_ntaps     = 301;
mf_40k(sym)      = sum(i, rrc40k_ntaps, rrc40k_coeff(i) * (sym@i));

// ── RRC Matched Filter — 125-tap (96 kbaud, sps≈20.83) ──────────────────────
rrc96k_coeffs = waveform {
  -0.000060486, -0.000095529, -0.000132502, -0.000164450, -0.000181251, -0.000169511, -0.000112782,
  0.000007802, 0.000212421, 0.000520955, 0.000950869, 0.001514632, 0.002216781, 0.003050780,
  0.003995869, 0.005014165, 0.006048304, 0.007019927, 0.007829333, 0.008356596, 0.008464386,
  0.008002695, 0.006815541, 0.004749641, 0.001664878, -0.002553714, -0.007982918, -0.014647807,
  -0.022508439, -0.031447563, -0.041260184, -0.051645847, -0.062204472, -0.072436466, -0.081747718,
  -0.089459849, -0.094825912, -0.097051399, -0.095320169, -0.088824594, -0.076798934, -0.058554689,
  -0.033516474, -0.001256808, 0.038471893, 0.085709789, 0.140268160, 0.201715437, 0.269371871,
  0.342313649, 0.419386867, 0.499231341, 0.580313756, 0.660969210, 0.739449783, 0.813978371,
  0.882805734, 0.944268493, 0.996845690, 1.039211549, 1.070282189, 1.089254263, 1.095633841,
  1.089254263, 1.070282189, 1.039211549, 0.996845690, 0.944268493, 0.882805734, 0.813978371,
  0.739449783, 0.660969210, 0.580313756, 0.499231341, 0.419386867, 0.342313649, 0.269371871,
  0.201715437, 0.140268160, 0.085709789, 0.038471893, -0.001256808, -0.033516474, -0.058554689,
  -0.076798934, -0.088824594, -0.095320169, -0.097051399, -0.094825912, -0.089459849, -0.081747718,
  -0.072436466, -0.062204472, -0.051645847, -0.041260184, -0.031447563, -0.022508439, -0.014647807,
  -0.007982918, -0.002553714, 0.001664878, 0.004749641, 0.006815541, 0.008002695, 0.008464386,
  0.008356596, 0.007829333, 0.007019927, 0.006048304, 0.005014165, 0.003995869, 0.003050780,
  0.002216781, 0.001514632, 0.000950869, 0.000520955, 0.000212421, 0.000007802, -0.000112782,
  -0.000169511, -0.000181251, -0.000164450, -0.000132502, -0.000095529, -0.000060486
};
rrc96k_coeff(n)  = rrc96k_coeffs, int(n) : rdtable;
rrc96k_ntaps     = 125;
mf_96k(sym)      = sum(i, rrc96k_ntaps, rrc96k_coeff(i) * (sym@i));

// ── Filter selector ───────────────────────────────────────────────────────────
matched_filter(sym) = select2(rrc_mode, mf_40k(sym), mf_96k(sym));

// ── Full demodulator ─────────────────────────────────────────────────────────
wideband_demod(i_in, q_in) = costas_loop(i_in, q_in)
                            : matched_filter
                            : (_ * output_gain);

// ── Main: 2 inputs (I, Q) → 1 output (soft symbol) ──────────────────────────
process = wideband_demod;
