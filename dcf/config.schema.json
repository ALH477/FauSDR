{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AudioNet Configuration Schema",
  "description": "Configuration schema for AudioNet modern dial-up style modulator system",
  "type": "object",
  "properties": {
    "modulator_type": {
      "description": "Type of modulator to use",
      "type": "string",
      "enum": ["audionet", "audionet_mono", "audionet_stereo", "audionet_legacy", "high_speed"],
      "default": "audionet"
    },
    "audio_mode": {
      "description": "Audio hardware configuration",
      "type": "string",
      "enum": ["mono", "stereo"],
      "default": "stereo"
    },
    "sample_rate": {
      "description": "Audio sample rate in Hz",
      "type": "integer",
      "enum": [44100, 48000, 96000, 192000],
      "default": 48000
    },
    "carrier_frequency": {
      "description": "Carrier frequency configuration",
      "type": "object",
      "properties": {
        "primary": {
          "description": "Primary carrier frequency for left channel",
          "type": "integer",
          "minimum": 1000,
          "maximum": 4000,
          "default": 2200
        },
        "secondary": {
          "description": "Secondary carrier frequency for right channel (stereo mode)",
          "type": "integer",
          "minimum": 1000,
          "maximum": 4000,
          "default": 2600
        },
        "offset": {
          "description": "Frequency offset between channels in stereo mode",
          "type": "integer",
          "minimum": 0,
          "maximum": 2000,
          "default": 400
        }
      },
      "required": ["primary"]
    },
    "symbol_rate": {
      "description": "Symbol rate configuration",
      "type": "object",
      "properties": {
        "primary": {
          "description": "Primary symbol rate for left channel",
          "type": "integer",
          "minimum": 1200,
          "maximum": 38400,
          "default": 9600
        },
        "secondary": {
          "description": "Secondary symbol rate for right channel (stereo mode)",
          "type": "integer",
          "minimum": 1200,
          "maximum": 38400,
          "default": 4800
        }
      },
      "required": ["primary"]
    },
    "modulation": {
      "description": "Modulation parameters",
      "type": "object",
      "properties": {
        "modulation_index": {
          "description": "Modulation index for sound character",
          "type": "number",
          "minimum": 0,
          "maximum": 6.28318,
          "default": 3.14159
        },
        "rrc_rolloff": {
          "description": "RRC filter rolloff factor",
          "type": "number",
          "minimum": 0.1,
          "maximum": 0.9,
          "default": 0.35
        },
        "output_gain": {
          "description": "Output gain control",
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.8
        }
      },
      "required": ["modulation_index", "rrc_rolloff", "output_gain"]
    },
    "stereo_config": {
      "description": "Stereo-specific configuration",
      "type": "object",
      "properties": {
        "independent_channels": {
          "description": "Enable independent channel configuration",
          "type": "boolean",
          "default": true
        },
        "channel_linking": {
          "description": "Link right channel to left with offset when disabled",
          "type": "boolean",
          "default": false
        }
      },
      "required": ["independent_channels"]
    },
    "sound_profile": {
      "description": "Predefined sound profiles for nostalgic experience",
      "type": "string",
      "enum": ["deep_bbs", "classic_modem", "high_speed", "ultra_clear"],
      "default": "classic_modem"
    },
    "connection_simulation": {
      "description": "Dial-up connection state simulation",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Enable connection state simulation",
          "type": "boolean",
          "default": false
        },
        "connection_state": {
          "description": "Current connection state",
          "type": "string",
          "enum": ["idle", "dialing", "handshake", "connected", "disconnecting"],
          "default": "idle"
        }
      },
      "required": ["enabled"]
    },
    "audio_quality": {
      "description": "Audio quality preset",
      "type": "string",
      "enum": ["standard", "high", "studio"],
      "default": "high"
    },
    "transport": {
      "description": "Transport layer configuration",
      "type": "object",
      "properties": {
        "protocol": {
          "description": "Transport protocol",
          "type": "string",
          "enum": ["udp", "tcp", "serial", "bluetooth"],
          "default": "udp"
        },
        "port": {
          "description": "Network port for UDP/TCP",
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "default": 8888
        },
        "device": {
          "description": "Serial device path",
          "type": "string",
          "default": "/dev/ttyUSB0"
        }
      },
      "required": ["protocol"]
    },
    "performance": {
      "description": "Performance tuning parameters",
      "type": "object",
      "properties": {
        "buffer_size": {
          "description": "Audio buffer size in samples",
          "type": "integer",
          "enum": [64, 128, 256, 512, 1024, 2048],
          "default": 512
        },
        "latency_mode": {
          "description": "Latency optimization mode",
          "type": "string",
          "enum": ["low", "balanced", "high"],
          "default": "balanced"
        },
        "cpu_priority": {
          "description": "CPU priority for audio processing",
          "type": "string",
          "enum": ["low", "normal", "high", "realtime"],
          "default": "normal"
        }
      },
      "required": ["buffer_size", "latency_mode"]
    }
  },
  "required": [
    "modulator_type",
    "audio_mode",
    "sample_rate",
    "carrier_frequency",
    "symbol_rate",
    "modulation",
    "transport"
  ],
  "additionalProperties": false
}